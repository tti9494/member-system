# 암호화 (각각 32자리 랜덤 문자열)
CODE_SECRET_KEY=your_32_char_random_string_here__
PHONE_SECRET_KEY=your_32_char_random_string_here__
EMAIL_SECRET_KEY=your_32_char_random_string_here__

# 텔레그램
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

# 이메일 발송 (선택)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Google Sheets
GAS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# 서비스 설정
SERVICE_NAME=AI 모임
MIN_AGE=14
CODE_EXPIRE_DAYS=30
CODE_MAX_FAIL=5
CODE_LOCK_HOURS=24

# 개인정보처리방침
PRIVACY_VERSION=1.0
PRIVACY_MANAGER=윤상욱
